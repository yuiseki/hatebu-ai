{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "groupName": "react",
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom"
      ]
    },
    {
      "groupName": "eslint",
      "matchPackageNames": [
        "@types/eslint",
        "babel-eslint",
        "@typescript-eslint/{/,}**",
        "eslint{/,}**"
      ]
    },
    {
      "groupName": "vite",
      "matchPackageNames": [
        "vite",
        "@vitejs/{/,}**"
      ]
    }
  ]
}
